<manifest xmlns:android="http://schemas.android.com/apk/res/android" package="org.archpheneos.manager">
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>
    <uses-sdk android:minSdkVersion="23" android:targetSdkVersion="36" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <application
        android:theme="@style/AppTheme"
        android:label="ArchpheneOS Manager"
        android:allowBackup="false"
        android:debuggable="true"
        android:supportsRtl="true">
        <activity
            android:name="org.archpheneos.manager.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name="org.archpheneos.manager.LinuxAppManagerService"
            android:exported="false" />
    </application>
</manifest>
