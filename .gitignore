# Generated screenshots, UI dumps, reports, and test artifacts
/artifacts/
*.png
*.jpg
*.jpeg
*.webp
*-window.xml
window.xml
*-report.txt
*-logcat.txt
*-dmesg.txt

# Preserve intentional documentation assets if added later
!docs/**/*.png
!docs/**/*.jpg
!docs/**/*.jpeg
!docs/**/*.webp

# Android resource images are source assets, not test screenshots
!prototypes/**/res/**/*.png

