# -----------------------------------------------------------------------------
# Archphene repository
# Keep source, docs, scripts, patches, manifests, and intentional test fixtures.
# Ignore generated build outputs, local SDK/tooling, caches, emulator state,
# binaries, packages, logs, screenshots, and temporary files.
# -----------------------------------------------------------------------------

# OS / editor files
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~
.vscode/
.idea/

# Environment / secrets
.env
.env.*
!.env.example
*.keystore
*.jks
*.p12
*.pfx
*.pem
*.key

# Logs / temporary files
*.log
*.pid
*.tmp
*.temp
*.bak
*.old
*.orig
*.rej
*.stackdump

# Archives / downloaded packages
*.zip
*.tar
*.tar.gz
*.tgz
*.tar.xz
*.tar.zst
*.7z
*.rar
*.jar
*.pkg.tar.zst

# Compiled binaries and libraries
*.exe
*.dll
*.so
*.so.*
*.a
*.o
*.obj
*.lib
*.dylib
*.class
*.dex
*.idsig

